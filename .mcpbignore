# Ignore build artifacts and temporary files
.mcpb_build/
*.mcpb
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.dylib
*.egg-info/
dist/
build/

# Ignore virtual environments and dependencies
venv/
env/
ENV/
mcp_server/venv/
mcp_server/lib/
node_modules/

# Ignore data files (users will upload their own)
data/
*.csv

# Ignore test files and scripts
test_*.py
*_test.py
tests/
