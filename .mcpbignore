# Ignore documentation that's not essential for the bundle
BIGQUERY_CROSSTAB_GUIDE.md
FIX_SUMMARY.md
INSTALLATION.md
QUICKSTART.md
SOLUTION.md

# Ignore build and packaging scripts
build.sh
pack_mcpb.sh
requirements.txt

# Ignore git files
.git/
.gitignore
.gitattributes

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Ignore old manifest and config files
mcp_server/mcpb.json

# Ignore synthetic data (users can generate their own if needed)
synthetic_data/
